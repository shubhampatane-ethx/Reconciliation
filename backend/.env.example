# Copy to .env (or set these in your shell / docker-compose) before running
# the backend or Alembic.

# Either set DATABASE_URL directly...
DATABASE_URL=postgresql://consistency:consistency@localhost:5432/consistency

# ...or set the individual Postgres pieces (used to build DATABASE_URL if
# it isn't set — see backend/database.py).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=consistency
POSTGRES_USER=consistency
POSTGRES_PASSWORD=consistency

# JWT
JWT_SECRET=replace-this-with-a-secure-random-secret-in-production
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24

# Ollama (unrelated to auth, existing config)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Dummy Server integration (backend/dummy_integration/) ---
# Base URL of the independent Dummy Server (backend/dummy_server/app.py,
# port 9000 by default). Inside docker-compose this is set automatically
# to http://dummy_server:9000 — only needed here for running the backend
# outside Docker.
DUMMY_SERVER_BASE_URL=http://localhost:9000
DUMMY_SERVER_TIMEOUT_SECONDS=10
# How often (minutes) the background scheduler auto-fetches Target data
# and reconciles against the most recently uploaded Source batch.
SCHEDULER_INTERVAL_MINUTES=10
